# From Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_whatsapp_business_account_id

# Your Meta app's numeric ID (App Dashboard > Settings > Basic).
# Only needed for uploading sample media for template headers (resumable upload API).
META_APP_ID=your_meta_app_id

# System user permanent token (Business Settings > System users > Generate token)
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token

# Any string you choose. Enter the same value in the Meta webhook config.
WEBHOOK_VERIFY_TOKEN=choose-a-random-string

GRAPH_API_VERSION=v23.0
PORT=3000
DEFAULT_COUNTRY_CODE=91
